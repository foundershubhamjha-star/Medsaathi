function FirstAidCard({ data }) {
  const [step, setStep] = useState(0);
  return (
    <div style={{ animation:"slideUp 0.3s ease" }}>
      <div style={{ background:data.color, borderRadius:"14px 14px 0 0", padding:"16px 18px", color:"white" }}>
        <div style={{ fontSize:11, opacity:0.7, textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:4 }}>🏥 Emergency First Aid</div>
        <div style={{ fontSize:20, fontWeight:800 }}>{data.title}</div>
      </div>
      <div style={{ background:"white", border:"1px solid #E5E7EB", borderTop:"none", borderRadius:"0 0 14px 14px" }}>
        {/* Steps */}
        <div style={{ padding:"14px 18px", borderBottom:"1px solid #F3F4F6" }}>
          <div style={{ fontSize:10, fontWeight:700, color:"#6B7280", textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:12 }}>Step-by-step kya karein</div>
          {data.steps.map((s,i)=>(
            <div key={i} onClick={()=>setStep(i)} style={{ display:"flex", gap:12, marginBottom:10, cursor:"pointer", opacity:step===i?1:0.6, transition:"opacity 0.2s" }}>
              <div style={{ width:24, height:24, borderRadius:"50%", background:step===i?data.color:"#E5E7EB", color:step===i?"white":"#6B7280", display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:700, flexShrink:0, transition:"all 0.2s" }}>{i+1}</div>
              <p style={{ fontSize:13, color:"#1F2937", margin:0, lineHeight:1.7, fontWeight:step===i?600:400 }}>{s}</p>
            </div>
          ))}
        </div>
        {/* Don'ts */}
        <div style={{ padding:"14px 18px", borderBottom:"1px solid #F3F4F6", background:"#FEF2F2" }}>
          <div style={{ fontSize:10, fontWeight:700, color:"#991B1B", textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:8 }}>❌ Bilkul mat karein</div>
          {data.donts.map((d,i)=>(
            <div key={i} style={{ display:"flex", gap:8, marginBottom:6, alignItems:"flex-start" }}>
              <span style={{ color:"#DC2626", flexShrink:0, fontWeight:700 }}>✗</span>
              <span style={{ fontSize:13, color:"#7F1D1D" }}>{d}</span>
            </div>
          ))}
        </div>
        {/* Emergency */}
        <div style={{ padding:"14px 18px", background:data.bg, borderRadius:"0 0 14px 14px" }}>
          <div style={{ fontSize:10, fontWeight:700, color:data.color, textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:6 }}>📞 Emergency Numbers</div>
          <p style={{ fontSize:14, fontWeight:700, color:data.color, margin:0 }}>{data.emergency}</p>
        </div>
      </div>
    </div>
  );
}

function UnknownCard({ text }) {
  return (
    <div style={{ background:"white", border:"1px solid #E5E7EB", borderRadius:14, padding:"18px", animation:"slideUp 0.3s ease" }}>
      <div style={{ fontSize:24, marginBottom:8 }}>🔍</div>
      <p style={{ fontSize:14, color:"#374151", lineHeight:1.8, margin:0, whiteSpace:"pre-line" }}>{text}</p>
    </div>
  );
}

function TypingDots() {
  return (
    <div style={{ display:"flex", gap:4, padding:"12px 16px", background:"#F3F4F6", borderRadius:"0 14px 14px 14px", width:"fit-content" }}>
      {[0,1,2].map(i=>(
        <div key={i} style={{ width:8, height:8, borderRadius:"50%", background:"#9CA3AF", animation:`bounce 1.2s ease-in-out ${i*0.2}s infinite` }}/>
      ))}
    </div>
  );
}

// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function MedSaathi() {
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const [activeTab, setActiveTab] = useState("chat");
  const [lang, setLang] = useState("HI");
  const [offlineMode, setOfflineMode] = useState(true);
  const bottomRef = useRef(null);
  const inputRef = useRef(null);

  useEffect(() => {
    // Welcome message
    setTimeout(() => {
      setMessages([{
        id:1, role:"assistant", type:"welcome",
        text:"Namaste! 🙏 Main MedSaathi hoon — aapka medicine saathi.\n\nMujhse poochhen:\n• Koi bhi medicine kya kaam karti hai\n• Jan Aushadhi mein sasta option kya hai\n• Koi medicine banned hai ya nahi\n• Emergency first aid (saanp, jalna, cpr, dog bite...)\n\nHindi, English, ya Hinglish — jo comfortable ho!"
      }]);
    }, 400);
  }, []);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior:"smooth" });
  }, [messages, loading]);

  const send = (text) => {
    const q = (text || input).trim();
    if (!q) return;
    setInput("");
    const userMsg = { id:Date.now(), role:"user", text:q };
    setMessages(prev=>[...prev, userMsg]);
    setLoading(true);
    setTimeout(() => {
      const result = processQuery(q);
      const response = buildResponse(result, q);
      setMessages(prev=>[...prev, { id:Date.now()+1, role:"assistant", ...response }]);
      setLoading(false);
    }, 900 + Math.random()*400);
  };

  const renderAssistantMessage = (msg) => {
    if (msg.type==="welcome") return <div style={{ fontSize:14, color:"#374151", lineHeight:1.9, whiteSpace:"pre-line" }}>{msg.text}</div>;
    if (msg.type==="drug") return <DrugCard data={msg.data}/>;
    if (msg.type==="banned") return <BannedCard data={msg.data}/>;
    if (msg.type==="nsq") return <NSQCard data={msg.data}/>;
    if (msg.type==="firstaid") return <FirstAidCard data={msg.data}/>;
    if (msg.type==="unknown") return <UnknownCard text={msg.text}/>;
    return null;
  };

  return (
    <div style={{ fontFamily:"'DM Sans', system-ui, sans-serif", background:"#F8FAFC", minHeight:"100vh", display:"flex", flexDirection:"column", maxWidth:520, margin:"0 auto" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap');
        @keyframes slideUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
        @keyframes bounce { 0%,80%,100% { transform:translateY(0); } 40% { transform:translateY(-8px); } }
        @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
        * { box-sizing:border-box; }
        ::-webkit-scrollbar { width:4px; }
        ::-webkit-scrollbar-track { background:transparent; }
        ::-webkit-scrollbar-thumb { background:#D1D5DB; border-radius:2px; }
      `}</style>

      {/* ── HEADER ── */}
      <div style={{ background:"linear-gradient(135deg,#1E3A5F 0%,#0F2340 100%)", padding:"14px 16px 0", position:"sticky", top:0, zIndex:50 }}>
        {/* Top bar */}
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:12 }}>
          <div style={{ display:"flex", alignItems:"center", gap:10 }}>
            <div style={{ width:38, height:38, borderRadius:12, background:"linear-gradient(135deg,#F59E0B,#D97706)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:20 }}>🏥</div>
            <div>
              <div style={{ color:"white", fontWeight:800, fontSize:18, letterSpacing:"-0.02em" }}>MedSaathi</div>
              <div style={{ color:"rgba(255,255,255,0.5)", fontSize:11 }}>Aapka Medicine Companion</div>
            </div>
          </div>
          <div style={{ display:"flex", gap:8, alignItems:"center" }}>
            {/* Offline badge */}
            <div onClick={()=>setOfflineMode(!offlineMode)} style={{ display:"flex", alignItems:"center", gap:5, background:offlineMode?"rgba(16,185,129,0.2)":"rgba(239,68,68,0.2)", border:`1px solid ${offlineMode?"rgba(16,185,129,0.4)":"rgba(239,68,68,0.4)"}`, borderRadius:20, padding:"3px 10px", cursor:"pointer" }}>
              <div style={{ width:6, height:6, borderRadius:"50%", background:offlineMode?"#10B981":"#EF4444", animation:"pulse 2s infinite" }}/>
              <span style={{ fontSize:10, color:offlineMode?"#6EE7B7":"#FCA5A5", fontWeight:600 }}>{offlineMode?"OFFLINE":"ONLINE"}</span>
            </div>
            {/* Language */}
            <div onClick={()=>setLang(l=>l==="HI"?"EN":l==="EN"?"TE":"HI")} style={{ background:"rgba(255,255,255,0.1)", borderRadius:20, padding:"3px 12px", cursor:"pointer" }}>
              <span style={{ fontSize:11, color:"rgba(255,255,255,0.8)", fontWeight:600 }}>{lang}</span>
            </div>
          </div>
        </div>
        {/* Tabs */}
        <div style={{ display:"flex", gap:0 }}>
          {[["chat","💬 Chat"],["firstaid","🚨 First Aid"],["jastore","🏪 JA Store"]].map(([id,label])=>(
            <button key={id} onClick={()=>setActiveTab(id)} style={{ flex:1, background:"transparent", border:"none", padding:"8px 0", cursor:"pointer", borderBottom:`2px solid ${activeTab===id?"#F59E0B":"transparent"}`, color:activeTab===id?"#F59E0B":"rgba(255,255,255,0.5)", fontSize:12, fontWeight:activeTab===id?700:400, transition:"all 0.2s", fontFamily:"inherit" }}>{label}</button>
          ))}
        </div>
      </div>

      {/* ── CHAT TAB ── */}
      {activeTab==="chat" && (
        <>
          {/* Messages */}
          <div style={{ flex:1, overflowY:"auto", padding:"16px", display:"flex", flexDirection:"column", gap:12, minHeight:400 }}>
            {messages.map(msg=>(
              <div key={msg.id} style={{ display:"flex", flexDirection:"column", alignItems:msg.role==="user"?"flex-end":"flex-start", gap:4 }}>
                {msg.role==="user" ? (
                  <div style={{ background:"linear-gradient(135deg,#1E3A5F,#2563EB)", color:"white", borderRadius:"14px 14px 0 14px", padding:"10px 14px", maxWidth:"85%", fontSize:14, lineHeight:1.6, boxShadow:"0 2px 8px rgba(30,58,95,0.3)" }}>{msg.text}</div>
                ) : (
                  <div style={{ maxWidth:"95%", width:"100%" }}>
                    {renderAssistantMessage(msg)}
                  </div>
                )}
              </div>
            ))}
            {loading && (
              <div style={{ display:"flex", flexDirection:"column", alignItems:"flex-start" }}>
                <div style={{ fontSize:10, color:"#9CA3AF", marginBottom:4, marginLeft:4 }}>MedSaathi soch raha hai...</div>
                <TypingDots/>
              </div>
            )}
            <div ref={bottomRef}/>
          </div>

          {/* Quick queries */}
          {messages.length <= 1 && (
            <div style={{ padding:"0 16px 12px", overflowX:"auto" }}>
              <div style={{ fontSize:11, color:"#9CA3AF", marginBottom:8, fontWeight:600, letterSpacing:"0.05em" }}>POPULAR QUERIES</div>
              <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
                {QUICK_QUERIES.map((q,i)=>(
                  <button key={i} onClick={()=>send(q)} style={{ background:"white", border:"1px solid #E5E7EB", borderRadius:20, padding:"5px 12px", fontSize:12, color:"#374151", cursor:"pointer", whiteSpace:"nowrap", fontFamily:"inherit", transition:"all 0.15s" }} onMouseEnter={e=>{ e.target.style.background="#EFF6FF"; e.target.style.borderColor="#93C5FD"; }} onMouseLeave={e=>{ e.target.style.background="white"; e.target.style.borderColor="#E5E7EB"; }}>{q}</button>
                ))}
              </div>
            </div>
          )}

          {/* Input */}
          <div style={{ padding:"12px 16px", background:"white", borderTop:"1px solid #F3F4F6", display:"flex", gap:10, alignItems:"flex-end" }}>
            <div style={{ flex:1, background:"#F9FAFB", border:"1px solid #E5E7EB", borderRadius:14, padding:"10px 14px", display:"flex", alignItems:"center", gap:8 }}>
              <input ref={inputRef} value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==="Enter"&&!e.shiftKey&&(e.preventDefault(),send())} placeholder="Medicine ka naam ya sawaal..." style={{ flex:1, background:"transparent", border:"none", outline:"none", fontSize:14, color:"#1F2937", fontFamily:"inherit" }}/>
              {/* Camera icon */}
              <button title="Prescription photo upload" style={{ background:"transparent", border:"none", cursor:"pointer", fontSize:18, opacity:0.5, padding:0 }}>📷</button>
              {/* Mic icon */}
              <button title="Voice query" style={{ background:"transparent", border:"none", cursor:"pointer", fontSize:18, opacity:0.5, padding:0 }}>🎤</button>
            </div>
            <button onClick={()=>send()} disabled={!input.trim()||loading} style={{ width:44, height:44, borderRadius:12, background:input.trim()&&!loading?"linear-gradient(135deg,#F59E0B,#D97706)":"#E5E7EB", border:"none", cursor:input.trim()&&!loading?"pointer":"default", display:"flex", alignItems:"center", justifyContent:"center", fontSize:20, transition:"all 0.2s", flexShrink:0 }}>
              {loading?"⏳":"→"}
            </button>
          </div>
        </>
      )}

      {/* ── FIRST AID TAB ── */}
      {activeTab==="firstaid" && (
        <div style={{ padding:16, display:"flex", flexDirection:"column", gap:12 }}>
          <div style={{ fontSize:12, color:"#6B7280", fontWeight:600, letterSpacing:"0.05em" }}>EMERGENCY FIRST AID — OFFLINE AVAILABLE</div>
          {Object.entries(FIRST_AID).map(([key,fa])=>(
            <div key={key} onClick={()=>{ setActiveTab("chat"); setTimeout(()=>{ send(key==="saanp"?"saanp ne kaata":key==="jalna"?"jal gaya":key==="dube"?"doob gaya":key==="cpr"?"CPR":"kutta ne kaata"); },100); }} style={{ background:"white", border:"1px solid #E5E7EB", borderRadius:14, padding:"14px 16px", cursor:"pointer", display:"flex", alignItems:"center", gap:12, transition:"all 0.15s" }} onMouseEnter={e=>e.currentTarget.style.borderColor=fa.color} onMouseLeave={e=>e.currentTarget.style.borderColor="#E5E7EB"}>
              <div style={{ width:44, height:44, borderRadius:12, background:fa.bg, display:"flex", alignItems:"center", justifyContent:"center", fontSize:22, flexShrink:0 }}>{fa.title.substring(0,2)}</div>
              <div>
                <div style={{ fontSize:14, fontWeight:700, color:"#1F2937" }}>{fa.title}</div>
                <div style={{ fontSize:12, color:"#6B7280", marginTop:2 }}>{fa.steps.length} steps · Emergency: {fa.emergency.split("·")[0]}</div>
              </div>
              <div style={{ marginLeft:"auto", color:"#9CA3AF", fontSize:18 }}>›</div>
            </div>
          ))}
          <div style={{ background:"#FEF2F2", borderRadius:12, padding:"12px 14px", border:"1px solid #FCA5A5" }}>
            <p style={{ fontSize:12, color:"#7F1D1D", margin:0, lineHeight:1.7 }}>🚨 <strong>Emergency numbers:</strong> 108 (Ambulance) · 102 (Medical) · 15400 (Snakebite/Rabies) · 1800-180-1104 (Poison Control)</p>
          </div>
        </div>
      )}

      {/* ── JA STORE TAB ── */}
      {activeTab==="jastore" && (
        <div style={{ padding:16 }}>
          <div style={{ background:"linear-gradient(135deg,#065F46,#059669)", borderRadius:14, padding:"16px", color:"white", marginBottom:16 }}>
            <div style={{ fontSize:20, fontWeight:800, marginBottom:4 }}>Jan Aushadhi Stores</div>
            <div style={{ fontSize:13, opacity:0.85 }}>10,000+ stores across India · Official govt generic medicines</div>
          </div>
          <div style={{ background:"white", border:"1px solid #E5E7EB", borderRadius:14, overflow:"hidden", marginBottom:12 }}>
            <div style={{ padding:"12px 14px", borderBottom:"1px solid #F3F4F6", background:"#F0FDF4" }}>
              <div style={{ fontSize:11, fontWeight:700, color:"#065F46", textTransform:"uppercase", letterSpacing:"0.05em" }}>How to find nearest store</div>
            </div>
            {[["🌐 Website","janaushadhi.gov.in/StoreLocator","Official locator"],["📱 App","Jan Aushadhi Suvidha App","Play Store / App Store"],["📞 Helpline","1800-11-8181","Toll free, Mon–Sat"],["🗺 Google Maps","Search 'Jan Aushadhi near me'","Usually within 2km in cities"]].map(([icon,name,sub],i)=>(
              <div key={i} style={{ display:"flex", gap:12, alignItems:"center", padding:"12px 14px", borderBottom:i<3?"1px solid #F3F4F6":"none" }}>
                <span style={{ fontSize:20 }}>{icon}</span>
                <div>
                  <div style={{ fontSize:13, fontWeight:600, color:"#1F2937" }}>{name}</div>
                  <div style={{ fontSize:11, color:"#6B7280" }}>{sub}</div>
                </div>
              </div>
            ))}
          </div>
          <div style={{ background:"white", border:"1px solid #E5E7EB", borderRadius:14, overflow:"hidden" }}>
            <div style={{ padding:"12px 14px", borderBottom:"1px solid #F3F4F6", background:"#F0FDF4" }}>
              <div style={{ fontSize:11, fontWeight:700, color:"#065F46", textTransform:"uppercase", letterSpacing:"0.05em" }}>Sample savings this month</div>
            </div>
            {[["Metformin 500mg × 90 tabs","Branded ₹288","JA ₹56","81% saved"],["Telmisartan 40mg × 30 tabs","Branded ₹213","JA ₹22.50","89% saved"],["Atorvastatin 10mg × 30 tabs","Branded ₹285","JA ₹24.75","91% saved"],["Augmentin 625 × 6 tabs","Branded ₹223","JA ₹52.60","76% saved"]].map(([drug,brand,ja,save],i)=>(
              <div key={i} style={{ padding:"10px 14px", borderBottom:i<3?"1px solid #F3F4F6":"none" }}>
                <div style={{ display:"flex", justifyContent:"space-between", marginBottom:4 }}>
                  <span style={{ fontSize:13, fontWeight:500, color:"#1F2937" }}>{drug}</span>
                  <span style={{ fontSize:12, color:"#059669", fontWeight:700 }}>{save}</span>
                </div>
                <div style={{ display:"flex", gap:12 }}>
                  <span style={{ fontSize:11, color:"#9CA3AF", textDecoration:"line-through" }}>{brand}</span>
                  <span style={{ fontSize:11, color:"#059669", fontWeight:600 }}>{ja}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ── FOOTER ── */}
      <div style={{ background:"white", borderTop:"1px solid #F3F4F6", padding:"10px 16px", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <div style={{ fontSize:10, color:"#9CA3AF" }}>MedSaathi v1.0 · Gemma 4 E4B · {offlineMode?"Offline":"Online"} Mode</div>
        <div style={{ fontSize:10, color:"#9CA3AF" }}>Not medical advice · Consult doctor</div>
      </div>
    </div>
  );
}
