        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start" }}>
          <div>
            <div style={{ fontSize:10, opacity:0.6, letterSpacing:"0.1em", textTransform:"uppercase", marginBottom:4 }}>{data.category}</div>
            <div style={{ fontSize:18, fontWeight:700 }}>{data.brand}</div>
            <div style={{ fontSize:12, opacity:0.75, marginTop:2 }}>{data.salt}</div>
          </div>
          <AlertBadge level="green"/>
        </div>
      </div>
      {/* Body */}
      <div style={{ background:"white", borderRadius:"0 0 14px 14px", border:"1px solid #E5E7EB", borderTop:"none" }}>
        {/* Uses */}
        <div style={{ padding:"14px 18px", borderBottom:"1px solid #F3F4F6" }}>
          <div style={{ fontSize:10, fontWeight:700, color:"#6B7280", textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:6 }}>Kya kaam aata hai</div>
          <p style={{ fontSize:13, color:"#374151", lineHeight:1.7, margin:0 }}>{data.uses}</p>
        </div>
        {/* Jan Aushadhi */}
        {data.ja_name && (
          <div style={{ padding:"14px 18px", borderBottom:"1px solid #F3F4F6", background:"#F0FDF4" }}>
            <div style={{ fontSize:10, fontWeight:700, color:"#065F46", textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:8 }}>✅ Jan Aushadhi Sasta Option</div>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10 }}>
              <div>
                <div style={{ fontSize:13, fontWeight:600, color:"#065F46" }}>{data.ja_name}</div>
                <div style={{ fontSize:11, color:"#6B7280" }}>{data.ja_unit}</div>
              </div>
              <div style={{ textAlign:"right" }}>
                <div style={{ fontSize:20, fontWeight:800, color:"#059669" }}>₹{data.ja_price}<span style={{ fontSize:12, fontWeight:400 }}>/tab</span></div>
