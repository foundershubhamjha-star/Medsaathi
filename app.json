  "Dolo 650 kya hai?","Augmentin 625 sasta option?","Corex cough syrup safe hai?",
  "Saanp ne kaata! Kya karein?","Metformin 500 batao","Voveran 50 SR kharidna chahiye?",
  "CPR kaise karein?","Telmisartan 40 Jan Aushadhi mein hai?","Dog ne kaata, kya karein?",
];

// ─── INTELLIGENCE ENGINE ─────────────────────────────────────────────────────
function processQuery(q) {
  const ql = q.toLowerCase().replace(/[?!।]/g,"").trim();
  // First aid detection
  const faKeys = { saanp:["saanp","snake","nag"], jalna:["jalna","burn","aag","jalana"], dube:["doob","drown","pani mein"], cpr:["cpr","dil","heart attack","behosh","unconscious","cardiac"], rabies:["kutta","dog","bite","rabies","janwar","animal"] };
  for (const [k,words] of Object.entries(faKeys)) {
    if (words.some(w=>ql.includes(w))) return { type:"firstaid", data:FIRST_AID[k] };
  }
  // Drug detection
  const drugKeys = Object.keys(DRUG_DB);
  const found = drugKeys.find(k=>ql.includes(k.replace(/\d/g,"").substring(0,5)) || ql.includes(k));
  if (found) return { type:"drug", data:DRUG_DB[found] };
  // Partial match
  const partial = drugKeys.find(k => { const words = ql.split(" "); return words.some(w=>w.length>3 && k.startsWith(w.substring(0,4))); });
  if (partial) return { type:"drug", data:DRUG_DB[partial] };
  return { type:"unknown" };
}

function buildResponse(result, query) {
  if (result.type==="unknown") return { type:"unknown", text:`Yeh medicine "${query}" abhi hamare database mein nahi hai.\n\nKya aap correct spelling ke saath dobara try karein? Ya koi popular brand name batayein (e.g. "Dolo 650", "Augmentin 625", "Metformin").` };
  if (result.type==="firstaid") return { type:"firstaid", data:result.data };
  const d = result.data;
  if (d.banned) return { type:"banned", data:d };
  if (d.nsq) return { type:"nsq", data:d };
  return { type:"drug", data:d };
}

// ─── COMPONENTS ──────────────────────────────────────────────────────────────
function AlertBadge({ level }) {
  const cfg = { green:{ bg:"#D1FAE5",c:"#065F46",t:"✓ Safe" }, yellow:{ bg:"#FEF3C7",c:"#92400E",t:"⚠ Caution" }, red:{ bg:"#FEE2E2",c:"#991B1B",t:"✗ Banned" } }[level];
  return <span style={{ fontSize:11, padding:"2px 8px", borderRadius:12, background:cfg.bg, color:cfg.c, fontWeight:600, letterSpacing:"0.03em" }}>{cfg.t}</span>;
}

function SavingsBar({ savings }) {
  return (
    <div>
      <div style={{ display:"flex", justifyContent:"space-between", marginBottom:4 }}>
        <span style={{ fontSize:11, color:"#6B7280" }}>Branded</span>
        <span style={{ fontSize:11, fontWeight:600, color:"#059669" }}>You save {savings}%</span>
        <span style={{ fontSize:11, color:"#6B7280" }}>Jan Aushadhi</span>
      </div>
      <div style={{ height:6, background:"#E5E7EB", borderRadius:3, overflow:"hidden" }}>
        <div style={{ height:"100%", width:`${savings}%`, background:"linear-gradient(90deg,#F59E0B,#10B981)", borderRadius:3, transition:"width 1s ease" }}/>
      </div>
    </div>
  );
}

